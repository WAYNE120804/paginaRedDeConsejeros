generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPERADMIN
  SECRETARIO
  COMUNICACIONES
}

enum MandateStatus {
  ACTIVE
  ENDED
}

enum BoardPosition {
  PRESIDENTE
  VICEPRESIDENTE
  SECRETARIO
  VOCAL
}

enum EventType {
  PUBLIC_EVENT
  ASSEMBLY
  BOARD_MEETING
}

enum EventVisibility {
  PUBLIC
  HIDDEN
}

enum AttendanceSessionType {
  ASSEMBLY
  BOARD
  EVENT
}

enum AttendanceMode {
  QR
  MANUAL
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

enum PublicDocumentCategory {
  ESTATUTOS
  REGLAMENTOS
  LINEAMIENTOS
  COMUNICADOS
}

enum PublicDocumentStatus {
  PUBLISHED
  ARCHIVED
}

model AdminUser {
  id                        String              @id @default(uuid())
  email                     String              @unique
  passwordHash              String              @map("password_hash")
  role                      AdminRole
  isActive                  Boolean             @default(true) @map("is_active")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")
  lastLoginAt               DateTime?           @map("last_login_at")
  auditLogs                 AuditLog[]
  attendanceSessionsCreated AttendanceSession[] @relation("attendance_sessions_creator")
  attendanceRecordsRecorded AttendanceRecord[]  @relation("attendance_records_recorder")

  @@map("admin_users")
}

model AuditLog {
  id           String     @id @default(uuid())
  actorAdminId String?    @map("actor_admin_id")
  actorAdmin   AdminUser? @relation(fields: [actorAdminId], references: [id])
  action       String
  entity       String
  entityId     String?    @map("entity_id")
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Person {
  id                     String                  @id @default(uuid())
  studentCode            String                  @unique @map("student_code")
  fullName               String                  @map("full_name")
  institutionalEmail     String                  @unique @map("institutional_email")
  phone                  String?
  publicDescription      String?                 @map("public_description")
  photoUrl               String?                 @map("photo_url")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  representativeMandates RepresentativeMandate[]
  leaders                Leader[]
  boardMandates          BoardMandate[]
  attendanceRecords      AttendanceRecord[]

  @@map("people")
}

model RepresentativeMandate {
  id         String        @id @default(uuid())
  personId   String        @map("person_id")
  person     Person        @relation(fields: [personId], references: [id])
  estateType String        @map("estate_type")
  faculty    String
  program    String
  startDate  DateTime      @map("start_date")
  endDate    DateTime?     @map("end_date")
  tshirtSize String?       @map("tshirt_size")
  status     MandateStatus @default(ACTIVE)
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([personId])
  @@map("representative_mandates")
}

model Leader {
  id          String    @id @default(uuid())
  personId    String    @map("person_id")
  person      Person    @relation(fields: [personId], references: [id])
  faculty     String
  program     String
  description String?
  startDate   DateTime  @map("start_date")
  isActive    Boolean   @default(true) @map("is_active")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([personId])
  @@map("leaders")
}

model BoardMandate {
  id        String        @id @default(uuid())
  personId  String        @map("person_id")
  person    Person        @relation(fields: [personId], references: [id])
  position  BoardPosition
  startDate DateTime      @map("start_date")
  endDate   DateTime?     @map("end_date")
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([personId])
  @@map("board_mandates")
}

model Event {
  id                 String              @id @default(uuid())
  slug               String              @unique
  title              String
  description        String
  type               EventType
  visibility         EventVisibility
  date               DateTime
  startTime          String              @map("start_time")
  endTime            String              @map("end_time")
  location           String
  createdAt          DateTime            @default(now()) @map("created_at")
  deletedAt          DateTime?           @map("deleted_at")
  photos             EventPhoto[]
  attendanceSessions AttendanceSession[]

  @@map("events")
}

model EventPhoto {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id])
  photoUrl  String   @map("photo_url")
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("event_photos")
}

model AttendanceSession {
  id               String                @id @default(uuid())
  type             AttendanceSessionType
  eventId          String?               @map("event_id")
  event            Event?                @relation(fields: [eventId], references: [id])
  name             String
  shortDescription String?               @map("short_description")
  token            String                @unique
  activeFrom       DateTime              @map("active_from")
  activeUntil      DateTime              @map("active_until")
  allowManual      Boolean               @default(false) @map("allow_manual")
  createdByAdminId String                @map("created_by_admin_id")
  createdByAdmin   AdminUser             @relation("attendance_sessions_creator", fields: [createdByAdminId], references: [id])
  createdAt        DateTime              @default(now()) @map("created_at")
  records          AttendanceRecord[]

  @@index([eventId])
  @@index([createdByAdminId])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                String            @id @default(uuid())
  sessionId         String            @map("session_id")
  session           AttendanceSession @relation(fields: [sessionId], references: [id])
  personId          String            @map("person_id")
  person            Person            @relation(fields: [personId], references: [id])
  mode              AttendanceMode
  timestamp         DateTime          @default(now())
  note              String?
  recordedByAdminId String?           @map("recorded_by_admin_id")
  recordedByAdmin   AdminUser?        @relation("attendance_records_recorder", fields: [recordedByAdminId], references: [id])

  @@unique([sessionId, personId])
  @@index([sessionId])
  @@index([personId])
  @@map("attendance_records")
}

model News {
  id            String     @id @default(uuid())
  slug          String     @unique
  title         String
  content       String
  status        NewsStatus @default(DRAFT)
  publishedAt   DateTime?  @map("published_at")
  coverPhotoUrl String?    @map("cover_photo_url")
  createdAt     DateTime   @default(now()) @map("created_at")

  @@map("news")
}

model PublicDocument {
  id          String                 @id @default(uuid())
  category    PublicDocumentCategory
  title       String
  description String?
  pdfUrl      String                 @map("pdf_url")
  publishedAt DateTime               @map("published_at")
  status      PublicDocumentStatus   @default(PUBLISHED)
  createdAt   DateTime               @default(now()) @map("created_at")

  @@map("public_documents")
}
